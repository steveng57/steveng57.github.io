{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open Related Post Files",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/open-post.ps1",
        "-Path",
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Open Related Post Files by Slug",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/open-post.ps1",
        "-Slug",
        "${input:postSlug}"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "postSlug",
      "type": "promptString",
      "description": "Post slug, for example walnut-frame"
    }
  ]
}
